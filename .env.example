# ══════════════════════════════════════════════
#  face-camera-gpu — Configuração
#  Copie para .env e edite com seus dados
# ══════════════════════════════════════════════

# ── Câmera Única (python app/main.py) ─────────
CAMERA_IP=192.168.0.10
CAMERA_USER=admin
CAMERA_PASSWORD=Master@92
# ATENÇÃO: @ na senha vira %40 na URL
CAMERA_RTSP_URL=rtsp://admin:Master%4092@192.168.0.10:554/cam/realmonitor?channel=1&subtype=0

# ── GPU ───────────────────────────────────────
GPU_REQUIRED=true
USE_CUDA=true

# ── Performance ───────────────────────────────
FRAME_SKIP=3
DETECTION_CONFIDENCE=0.65
RECOGNITION_THRESHOLD=0.55
VIDEO_WIDTH=1280
VIDEO_HEIGHT=720

# ── Base de Rostos ────────────────────────────
# false = modo pasta: known_faces/nome_pessoa/foto.jpg
# true  = modo plano: fotosFaceID/user_images/123.jpg
USE_FLAT_FACES=false
KNOWN_FACES_DIR=./known_faces
FLAT_FACES_DIR=../fotosFaceID/user_images

# ── Cache de Embeddings ───────────────────────
EMBEDDINGS_CACHE=./embeddings_cache.pkl

# ══════════════════════════════════════════════
#  MÚLTIPLAS CÂMERAS (python multi_main.py)
#  Adicione quantas câmeras quiser
# ══════════════════════════════════════════════

CAMERA_COUNT=4

# Tamanho de cada célula na grade 2x2 (px)
MULTI_CELL_W=640
MULTI_CELL_H=360

CAMERA_1_NAME=Entrada Principal
CAMERA_1_RTSP=rtsp://admin:Master%4092@192.168.0.10:554/cam/realmonitor?channel=1&subtype=0

CAMERA_2_NAME=Recepcao
CAMERA_2_RTSP=rtsp://admin:Master%4092@192.168.0.11:554/cam/realmonitor?channel=1&subtype=0

CAMERA_3_NAME=Corredor
CAMERA_3_RTSP=rtsp://admin:Master%4092@192.168.0.12:554/cam/realmonitor?channel=1&subtype=0

CAMERA_4_NAME=Estacionamento
CAMERA_4_RTSP=rtsp://admin:Master%4092@192.168.0.13:554/cam/realmonitor?channel=1&subtype=0
