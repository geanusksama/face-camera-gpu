# Câmera Intelbras
CAMERA_IP=192.168.0.10
CAMERA_USER=admin
CAMERA_PASSWORD=Master@92
CAMERA_RTSP_URL=rtsp://admin:Master%4092@192.168.0.10:554/cam/realmonitor?channel=1&subtype=0

# GPU
GPU_REQUIRED=true
USE_CUDA=true

# Performance
FRAME_SKIP=3
DETECTION_CONFIDENCE=0.65
RECOGNITION_THRESHOLD=0.55
VIDEO_WIDTH=1280
VIDEO_HEIGHT=720

# Base de imagens
# Modo pasta por pessoa: known_faces/nome_pessoa/foto.jpg
KNOWN_FACES_DIR=./known_faces

# Modo arquivo plano (ex: fotosFaceID/user_images/123.jpg -> ID=123)
# USE_FLAT_FACES=true para ativar
USE_FLAT_FACES=false
FLAT_FACES_DIR=../fotosFaceID/user_images

# Cache de embeddings (gerado automaticamente no primeiro uso)
EMBEDDINGS_CACHE=./embeddings_cache.pkl
